export type Condition = "Sıfır" | "Çok iyi" | "İyi" | "Orta";
export type PaymentStatus = "pending" | "held" | "released" | "refunded";
export type ShipmentStatus =
  "waiting" | "prepared" | "shipped" | "delivered" | "approved" | "disputed";
export type ModerationStatus = "pending" | "approved" | "rejected";
export type DisputeStatus =
  | "open"
  | "reviewing"
  | "resolved_buyer"
  | "resolved_seller";

export type Dispute = {
  id: string;
  orderId: string;
  openedBy: string;
  reason: string;
  details: string;
  status: DisputeStatus;
  createdAt: string;
  updatedAt: string;
};

export type AutoBid = {
  auctionId: string;
  userId: string;
  maxAmount: number;
  active: boolean;
  createdAt: string;
};

export type Auction = {
  id: string;
  title: string;
  category: string;
  image: string;
  currentBid: number;
  startingBid: number;
  bidCount: number;
  endsAt: string;
  city: string;
  seller: string;
  sellerId: string;
  verified: boolean;
  condition: Condition;
  description: string;
  minIncrement: number;
  reservePrice: number;
  favorite?: boolean;
  shipping: string;
  paymentHold: boolean;
  createdAt: string;
  extensionCount?: number;
};

export type Bid = {
  id: string;
  auctionId: string;
  userId: string;
  userName: string;
  amount: number;
  createdAt: string;
};

export type Notice = {
  id: string;
  title: string;
  text: string;
  createdAt: string;
  read: boolean;
  auctionId?: string;
};

export type Order = {
  id: string;
  auctionId: string;
  buyerId: string;
  sellerId: string;
  amount: number;
  paymentStatus: PaymentStatus;
  shipmentStatus: ShipmentStatus;
  carrier?: string;
  trackingNumber?: string;
  deliveryAddressId?: string;
  updatedAt: string;
};

export type Review = {
  id: string;
  orderId?: string;
  sellerId: string;
  reviewer: string;
  rating: number;
  text: string;
  product: string;
  createdAt: string;
};

export type ChatMessage = {
  id: string;
  conversationId: string;
  auctionId: string;
  senderId: string;
  senderName: string;
  body: string;
  createdAt: string;
  read: boolean;
};

export type WalletTransaction = {
  id: string;
  type: "deposit" | "sale" | "purchase" | "withdrawal" | "refund" | "hold";
  title: string;
  amount: number;
  createdAt: string;
  status: "completed" | "pending";
  orderId?: string;
};

export type VerificationState = {
  phone: boolean;
